# ===========================================================================
# Xentra Bot — Environment Variables Reference
# ===========================================================================
# Copy this file to .env and fill in your values:
#   cp bot/.env.example bot/.env
# ===========================================================================


# ═══════════════════════════════════════════════════════════════════════════
# 1. REQUIRED — Discord Bot
# ═══════════════════════════════════════════════════════════════════════════
# These are read at startup by bot/config.py.

# Discord bot token (from Discord Developer Portal).
DISCORD_TOKEN=

# Application / Client ID (from Discord Developer Portal).
APPLICATION_ID=


# ═══════════════════════════════════════════════════════════════════════════
# 2. REQUIRED — Webhook & Backend Connectivity
# ═══════════════════════════════════════════════════════════════════════════

# Backend API base URL (must end with /api/v1/).
BACKEND_URL=http://127.0.0.1:8000/api/v1/

# Frontend URL — REQUIRED.  The bot will refuse to start if unset.
FRONTEND_URL=http://localhost:3000

# Shared webhook secret — must match WEBHOOK_SECRET in backend/.env.
WEBHOOK_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# 3. CLUSTER COORDINATION (HA Deployment)
# ═══════════════════════════════════════════════════════════════════════════
# These are read by bot/config.py and bot/cluster_worker.py.

# Enable cluster coordination mode (True/False).
CLUSTER_ENABLED=False

# Unique node ID.  If empty, a random UUID is generated on first start.
CLUSTER_NODE_ID=

# Override cluster API base URL (defaults to BACKEND_URL).
CLUSTER_API_URL=

# Heartbeat interval in seconds (default: 30).
CLUSTER_HEARTBEAT_INTERVAL=30

# Shard count hint (used in registration; real count comes from Discord).
SHARD_COUNT=1

# Enable auto-sharding (True/False).
AUTO_SHARD=False


# ═══════════════════════════════════════════════════════════════════════════
# 4. WEBHOOK SERVER
# ═══════════════════════════════════════════════════════════════════════════

# Webhook server host (default: 0.0.0.0).
WEBHOOK_HOST=0.0.0.0

# Webhook server port (default: 5000).
# On Railway, the platform auto-assigns a PORT env variable — the entrypoint
# script and config.py both honour PORT as the fallback, so you typically
# do NOT need to set WEBHOOK_PORT explicitly when deploying on Railway.
# On HF Spaces, set WEBHOOK_PORT=7860 (the port HF expects).
WEBHOOK_PORT=5000


# ═══════════════════════════════════════════════════════════════════════════
# 5. RAILWAY-SPECIFIC (only used when deploying on Railway)
# ═══════════════════════════════════════════════════════════════════════════
# PORT is automatically set by the Railway platform — do NOT add it to
# your Railway Variables.  It is listed here only for documentation.
# The entrypoint.sh and config.py both use PORT as a fallback for
# WEBHOOK_PORT.
#
#   PORT            (set by Railway, not user-configurable)


# ═══════════════════════════════════════════════════════════════════════════
# 6. OPTIONAL — Development Only
# ═══════════════════════════════════════════════════════════════════════════

# Guild ID for development (slash commands sync to a single guild).
GUILD_ID=
