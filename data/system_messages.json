        "mandatory": false
      },
      {
        "name": "command_name",
        "description": "Command that was run (e.g. interview_budget); present = command notification mode",
        "mandatory": false
      },
      {
        "name": "executor_name",
        "description": "Display name of the person who ran the command (optional)",
        "mandatory": false
      },
      {
        "name": "msg_data",
        "description": "Execution details text (optional; for command notifications)",
        "mandatory": false
      }
    ]
  },
