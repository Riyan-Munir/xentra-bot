[
  {
    "name": "security_bypass_attempt",
    "description": "Notify user of a security bypass attempt detected on their account.",
    "context": [
      "dm"
    ],
    "requires_user": true,
    "fields": [
      {
        "name": "discord_id",
        "description": "Snowflake of the target user",
        "mandatory": true
      },
      {
        "name": "event_type",
        "description": "Category of the bypass (e.g. sql_injection_attempt)",
        "mandatory": true
      },
      {
        "name": "total_attempts",
        "description": "Cumulative bypass count for the user",
        "mandatory": true
      },
      {
        "name": "auto_ban_at",
        "description": "Threshold at which auto-ban triggers",
        "mandatory": false
      },
      {
        "name": "ip",
        "description": "Origin IP of the attempt",
        "mandatory": false
      },
      {
        "name": "path",
        "description": "API path that was targeted",
        "mandatory": false
      },
      {
        "name": "detail",
        "description": "Human-readable detail about the event",
        "mandatory": false
      }
    ]
  },
